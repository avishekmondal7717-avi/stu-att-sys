DATABASE_URL=postgresql://user:password@host:5432/database
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
HOST_URL=http://localhost:8000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-bootstrap-password
ADMIN_NAME=System Admin

# Optional S3-compatible profile photo storage
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=smart-attendance-photos
S3_PUBLIC_URL_TEMPLATE=

# Face recognition models and thresholds
FACE_DETECTION_MODEL_PATH=face_detection_yunet_2023mar.onnx
FACE_RECOGNITION_MODEL_PATH=face_recognition_sface_2021dec.onnx
FACE_MATCH_THRESHOLD=0.40
SELF_FACE_MATCH_THRESHOLD=0.48

# Password reset delivery. Leave SMTP_HOST empty during development; reset
# links are printed in the backend terminal and returned to the local UI.
FRONTEND_URL=http://localhost:5173
RESET_DEBUG=1
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
LIVENESS_LAPLACIAN_THRESHOLD=12.0
LIVENESS_YAW_CHANGE=0.10
FACE_DETECTOR_SCORE_THRESHOLD=0.9
FACE_DETECTOR_NMS_THRESHOLD=0.3
LOCAL_TIMEZONE_OFFSET_HOURS=5.5

# Set to 1 only when the API should run schema initialization at startup
RUN_DB_INIT_ON_STARTUP=0
